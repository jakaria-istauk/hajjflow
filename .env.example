# WordPress site URL (no trailing slash)
VITE_WP_URL=https://your-wp-site.com

# Google OAuth Client ID (same as HAJJFLOW_GOOGLE_CLIENT_ID in wp-config.php)
VITE_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# WordPress wp-config.php values — used for HMAC request signing
# Copy exact values from your wp-config.php
VITE_WP_LOGGED_IN_KEY=your_logged_in_key_here
VITE_WP_AUTH_SALT=your_auth_salt_here
